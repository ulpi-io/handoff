{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ulpi.io/handoff/contracts/v0.2/request.schema.json",
  "title": "Handoff v0.2 machine request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "instructions"],
  "properties": {
    "schemaVersion": { "const": "handoff.request.v0.2" },
    "instructions": { "type": "string", "minLength": 1, "maxLength": 2000000 },
    "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 3600000 },
    "maxTurns": { "type": "integer", "minimum": 1, "maximum": 100 },
    "webSearch": { "type": "boolean" },
    "model": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?![-\\s])[^\\u0000-\\u001F\\u007F]*\\S$" },
    "effort": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^(?![-\\s])[^\\u0000-\\u001F\\u007F]*\\S$" },
    "coordinatorApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "approvalId", "issuer", "provider", "role", "cwd", "scope", "subjectHash", "rules"],
      "properties": {
        "schemaVersion": { "const": "handoff.coordinator-approval.v0.2" },
        "approvalId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "issuer": { "type": "string", "minLength": 1, "maxLength": 256 },
        "provider": { "const": "codex" },
        "role": { "enum": ["build", "phase", "review", "verify"] },
        "cwd": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "scope": { "const": "all-applicable-agents-rules" },
        "subjectHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "rules": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "path", "sha256", "content"],
            "properties": {
              "source": { "enum": ["repository", "external"] },
              "path": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "(^|[\\\\/])(AGENTS|AGENTS\\.override)\\.md$" },
              "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
              "content": { "type": "string", "maxLength": 256000 }
            }
          }
        }
      }
    }
  }
}
