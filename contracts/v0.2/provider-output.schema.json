{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ulpi.io/handoff/contracts/v0.2/provider-output.schema.json",
  "title": "Handoff v0.2 provider output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "summary", "evidence", "findings", "usage"],
  "properties": {
    "schemaVersion": { "const": "handoff.provider-output.v0.2" },
    "status": { "enum": ["completed", "blocked", "failed"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 32768 },
    "evidence": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "summary"],
        "properties": {
          "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
          "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 8192 }
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "summary"],
        "properties": {
          "file": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "line": { "type": "integer", "minimum": 1 },
          "severity": { "enum": ["blocker", "high", "medium", "low", "nit"] },
          "summary": { "type": "string", "minLength": 1, "maxLength": 8192 }
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "totalTokens": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
